# BOB Quickstart — minimum required env vars
#
# Copy this file to .env and fill in the required values.
# Defaults are sensible — you only need to set the API key for your provider.

# ── LLM Provider ────────────────────────────────────────────────────────────
# Pick one: anthropic | openai | ollama
# Default: anthropic (best tool-calling reliability)
BOB_LLM_PROVIDER=anthropic

# Model name. Leave empty to use the provider's default:
#   anthropic → claude-opus-4-6
#   openai    → gpt-4o
#   ollama    → qwen2.5:14b
BOB_MODEL=

# Max tokens per response (default 8192)
BOB_LLM_MAX_TOKENS=8192

# Optional sampling temperature. Leave empty for the provider's default.
BOB_LLM_TEMPERATURE=

# Optional custom endpoint URL.
# Use this for self-hosted vLLM, LiteLLM proxy, LM Studio, custom Ollama hosts.
# Leave empty for the provider's default.
BOB_LLM_BASE_URL=

# ── Provider Keys ───────────────────────────────────────────────────────────
# Set the key for the provider you picked above. The other keys can be empty.

# Required if BOB_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required if BOB_LLM_PROVIDER=openai (or set OPENAI_API_KEY=EMPTY for vLLM/LM Studio)
OPENAI_API_KEY=

# Generic fallback if neither provider-specific key is set
BOB_LLM_API_KEY=

# ── Specialist Agents (quickstart only) ────────────────────────────────────
# These run their own LLM calls separate from BOB. They share ANTHROPIC_API_KEY
# above and use cheaper models by default. Override here if needed.
RESEARCHER_MODEL=claude-haiku-4-5
CODER_MODEL=claude-sonnet-4-5

# ── Logging (optional) ──────────────────────────────────────────────────────
BOB_LOG_LEVEL=info
BOB_LOG_FORMAT=text
