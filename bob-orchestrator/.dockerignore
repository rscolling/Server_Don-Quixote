# Keep secrets, local data, and cruft out of the Docker build context.
# Anything excluded here is NOT copied into the image during `docker build`.

# Secrets
.env
*.env
!*.env.example
credentials.json
token.json
gmail_token.json
gmail_credentials.json
mcp_servers.json
!mcp_servers.example.json

# Local data
data/
*.db
*.sqlite
*.sqlite3
*.jsonl
*.log

# Personal context (the operator should mount their own at runtime,
# not bake it into the image)
bob_context/MISSION.md
bob_context/IDEA_PARKING_LOT.md

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.python-version

# Tests
.pytest_cache/
.coverage
htmlcov/

# Git
.git/
.gitignore
.gitattributes

# CI / IDE
.github/
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Docs (not needed in the runtime image)
README.md
CONTRIBUTING.md
SECURITY.md
ROADMAP.md
LLM_PROVIDERS.md
MCP_INTEGRATION.md
LICENSE

# Quickstart (separate from the production image)
quickstart/

# Dashboard source (only dist/ is copied into the image)
dashboard/node_modules/
dashboard/src/
dashboard/public/
dashboard/package.json
dashboard/package-lock.json
dashboard/tsconfig*.json
dashboard/vite.config.ts
dashboard/index.html
dashboard/.gitignore

# Compose files for the host (not needed inside the image)
docker-compose.yml
docker-compose.override.yml
