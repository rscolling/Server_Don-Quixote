# BOB — Environment Configuration
#
# Copy this file to .env and fill in the values you need.
# Only the LLM provider key is strictly required. Everything else has
# sensible defaults or degrades gracefully if not configured.

# ════════════════════════════════════════════════════════════════════════════
# LLM PROVIDER (required)
# ════════════════════════════════════════════════════════════════════════════

# Pick one: anthropic | openai | ollama
BOB_LLM_PROVIDER=anthropic

# Model name. Leave empty to use the provider's default:
#   anthropic → claude-opus-4-6
#   openai    → gpt-4o
#   ollama    → qwen2.5:14b
BOB_MODEL=

# Max tokens per LLM response (default 8192)
BOB_LLM_MAX_TOKENS=8192

# Optional sampling temperature. Leave empty for the provider's default.
BOB_LLM_TEMPERATURE=

# Optional custom endpoint URL for OpenAI-compatible backends (vLLM, LiteLLM,
# LM Studio, OpenRouter, custom Ollama host, etc.)
BOB_LLM_BASE_URL=

# ── Provider Keys ───────────────────────────────────────────────────────────
# Set the key for the provider you picked above. The other keys can be empty.

# Required if BOB_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required if BOB_LLM_PROVIDER=openai
# (Or set OPENAI_API_KEY=EMPTY if you're pointing at vLLM / LM Studio)
OPENAI_API_KEY=

# Generic fallback if neither provider-specific key is set
BOB_LLM_API_KEY=

# ════════════════════════════════════════════════════════════════════════════
# CORE INFRASTRUCTURE
# ════════════════════════════════════════════════════════════════════════════

# Where BOB stores all SQLite databases, audit logs, and runtime data.
# In Docker this is the mounted volume.
BOB_DATA_DIR=/app/data

# FastAPI port for the orchestrator
BOB_PORT=8100

# Cross-agent shared memory
CHROMADB_URL=http://chromadb:8000

# Message bus for the debate arena (set to a dummy URL if you don't run one)
MESSAGE_BUS_URL=http://message-bus:8585

# Where the system prompt context files live
BOB_CONTEXT_DIR=/app/bob_context

# ════════════════════════════════════════════════════════════════════════════
# LOGGING
# ════════════════════════════════════════════════════════════════════════════

# debug | info | warning | error
BOB_LOG_LEVEL=info

# json (production, machine-parseable) or text (development, human-readable)
BOB_LOG_FORMAT=json

# ════════════════════════════════════════════════════════════════════════════
# MCP (Model Context Protocol)
# ════════════════════════════════════════════════════════════════════════════

# MCP CLIENT — fetch tools from external MCP servers at startup
MCP_CLIENT_ENABLED=true
MCP_CLIENT_CONFIG_PATH=/app/data/mcp_servers.json
MCP_CLIENT_FETCH_TIMEOUT=15.0

# MCP SERVER — expose BOB's high-level capabilities to other AI clients
# (Claude Desktop, Cursor, goose, etc.) See MCP_INTEGRATION.md.
MCP_SERVER_ENABLED=true
MCP_SERVER_PORT=8108
MCP_SERVER_TRANSPORT=sse
# Optional bearer token. Leave empty if behind Cloudflare Zero Trust.
MCP_SERVER_AUTH_TOKEN=

# ════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION (SaaS-ready)
# ════════════════════════════════════════════════════════════════════════════

# Auth backend: cloudflare | oidc | shared_secret | none
BOB_AUTH_BACKEND=cloudflare

# Comma-separated admin emails (full access, "Yes Boss" mode)
BOB_ADMIN_EMAILS=robert.colling@gmail.com,rob@appalachiantoysgames.com

# ── Cloudflare Zero Trust (default backend) ────────────────────────────────
# Supports Google, GitHub, Apple, Microsoft, email OTP — all configured in
# the Cloudflare Access dashboard. No code changes needed to add providers.
CF_TEAM_NAME=
CF_POLICY_AUD=

# ── Generic OIDC (Auth0, Okta, Keycloak, Google Sign-In, etc.) ────────────
# BOB_AUTH_OIDC_JWKS_URL=https://YOUR_TENANT.auth0.com/.well-known/jwks.json
# BOB_AUTH_OIDC_ISSUER=https://YOUR_TENANT.auth0.com/
# BOB_AUTH_OIDC_AUDIENCE=your-api-identifier
# BOB_AUTH_OIDC_HEADER=authorization

# ── Shared secret (self-hosted, no IdP) ───────────────────────────────────
# Single token (everyone is admin): BOB_AUTH_SHARED_SECRET=my-secret-token
# Multi-user map: BOB_AUTH_SHARED_SECRET={"token1":"alice@example.com","token2":"bob@example.com"}
# BOB_AUTH_SHARED_SECRET=
# BOB_AUTH_SHARED_SECRET_HEADER=x-bob-auth

# ════════════════════════════════════════════════════════════════════════════
# RATE LIMITING
# ════════════════════════════════════════════════════════════════════════════

# Per-IP limits on the public /chat endpoint
CHAT_RATE_LIMIT_PER_MIN=10
CHAT_RATE_LIMIT_PER_HOUR=60

# ════════════════════════════════════════════════════════════════════════════
# CORS
# ════════════════════════════════════════════════════════════════════════════

# Comma-separated list of allowed origins. Default allows localhost only.
# Add your production domains here.
CORS_ORIGINS=http://localhost:8100,http://localhost:8200

# ════════════════════════════════════════════════════════════════════════════
# SCHEDULER
# ════════════════════════════════════════════════════════════════════════════

# IANA timezone for scheduled tasks
SCHEDULER_TIMEZONE=America/New_York

# Daily briefing hour (24-hour, in SCHEDULER_TIMEZONE)
BOB_REPORT_HOUR=8
BOB_REPORT_MINUTE=0

# ════════════════════════════════════════════════════════════════════════════
# OPTIONAL INTEGRATIONS
# (BOB starts fine without these — they degrade gracefully)
# ════════════════════════════════════════════════════════════════════════════

# ── ntfy (push notifications to your phone) ────────────────────────────────
NTFY_URL=http://ntfy:80
NTFY_TOKEN=

# ── Langfuse (LLM observability) ───────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# ── Gmail (email triage — read-only by default) ─────────────────────────────
GMAIL_TOKEN_PATH=/app/gmail_token.json
GMAIL_CREDENTIALS_PATH=/app/gmail_credentials.json
GMAIL_POLL_INTERVAL=300

# ── Google Maps (Grounding Lite MCP — places, weather, routes) ─────────────
GOOGLE_MAPS_API_KEY=

# ── ElevenLabs (voice usage tracking + TTS for the voice service) ──────────
ELEVENLABS_API_KEY=

# ── Deepgram (STT for the voice service) ───────────────────────────────────
DEEPGRAM_API_KEY=

# ════════════════════════════════════════════════════════════════════════════
# TIMEOUTS (advanced — defaults are sensible)
# ════════════════════════════════════════════════════════════════════════════

SERVICE_TIMEOUT=30.0
HEALTH_CHECK_TIMEOUT=5.0
EXTERNAL_API_TIMEOUT=10.0

# ════════════════════════════════════════════════════════════════════════════
# AUDIT LOG
# ════════════════════════════════════════════════════════════════════════════

# Auto-rotates at this size, keeps 3 rotated files
AUDIT_LOG_MAX_SIZE_MB=10
